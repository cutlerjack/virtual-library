{
  "name": "virtual-library",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "test:e2e": "node scripts/playwright-test.mjs",
    "test:desktop": "node scripts/desktop-verify.mjs",
    "test:desktop-launch": "node scripts/desktop-launch-smoke.mjs",
    "test:desktop-e2e": "node scripts/desktop-smoke.mjs",
    "test:native": "cargo test --manifest-path src-tauri/Cargo.toml",
    "check:native": "cargo check --manifest-path src-tauri/Cargo.toml",
    "verify": "npm test -- --run && npm run build && npm run test:e2e && npm run check:native && npm run test:native && npm run test:desktop",
    "verify:fast": "npm test -- --run && npm run build && npm run check:native"
  },
  "dependencies": {
    "@tauri-apps/api": "^1.5.0",
    "epubjs": "^0.3.93",
    "framer-motion": "^11.0.0",
    "pdfjs-dist": "^5.4.530",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.13.1",
    "recharts": "^2.10.0",
    "tauri-plugin-sql-api": "github:tauri-apps/tauri-plugin-sql#v1",
    "tesseract.js": "^5.0.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tauri-apps/cli": "^1.5.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^6.0.0",
    "autoprefixer": "^10.4.16",
    "jsdom": "^27.0.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "vite": "^8.0.0",
    "vitest": "^3.2.4",
    "webdriverio": "^9.26.1"
  },
  "overrides": {
    "anymatch": {
      "picomatch": "^2.3.2"
    },
    "micromatch": {
      "picomatch": "^2.3.2"
    },
    "readdirp": {
      "picomatch": "^2.3.2"
    }
  }
}
