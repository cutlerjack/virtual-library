{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "package": {
    "productName": "Virtual Library",
    "version": "0.1.0"
  },
  "build": {
    "distDir": "../dist",
    "devPath": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "fs": {
        "all": false,
        "copyFile": true,
        "createDir": true,
        "exists": true,
        "readFile": true,
        "readDir": true,
        "renameFile": true,
        "writeFile": true,
        "scope": [
          "$HOME/VirtualLibrary/**",
          "$HOME/Downloads/**",
          "$HOME/Desktop/**",
          "$HOME/Documents/**"
        ]
      },
      "dialog": {
        "all": true
      },
      "path": {
        "all": true
      }
    },
    "windows": [
      {
        "title": "Virtual Library",
        "width": 980,
        "height": 720,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; base-uri 'self'; object-src 'none'; frame-src 'none'; form-action 'self'; connect-src 'self' ipc: http://ipc.localhost https://ipc.localhost asset: data: blob: http://localhost:5173 ws://localhost:5173 http: https:; img-src 'self' asset: data: blob: https:; style-src 'self' 'unsafe-inline'; font-src 'self' data: https:; script-src 'self' 'wasm-unsafe-eval'; worker-src 'self' blob:; media-src 'self' asset: blob:;"
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.tauri.virtual-library",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ]
    }
  }
}
